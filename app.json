{
  "expo": {
    "name": "Ghostposter",
    "slug": "ghostposter",
    "version": "1.3.0",
    "scheme": "ghostposter",
    "platforms": [
      "android"
    ],
    "icon": "./assets/icon.png",
    "android": {
      "package": "fr.gyozamancave.ghostposter",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#15171A"
      },
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ],
      "versionCode": 15
    },
    "plugins": [
      "expo-secure-store",
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Accès à la galerie pour insérer des images dans vos articles."
        }
      ],
      "expo-font",
      "expo-asset",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Accès au microphone pour la dictée vocale."
        }
      ],
      "expo-localization"
    ],
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
